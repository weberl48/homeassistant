# --- Alpaca ---
# Paper account (free, no funding). Sign up: https://alpaca.markets/ -> Paper Trading -> generate API keys.
# Switch to live keys ONLY after deleting data/.paper-only sentinel and reviewing paper results.
ALPACA_MODE=paper
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=

# --- Anthropic (for daily journal commentary; ~$0.50/mo on Haiku 4.5) ---
# https://console.anthropic.com/ -> API Keys
ANTHROPIC_API_KEY=

# --- Quiver Quantitative (political copy strategy; Phase 5, optional) ---
# Free tier first. Paid ($10-50/mo) only after political strategy validates on paper.
# Leave blank during Phases 1-4. https://www.quiverquant.com/api/
QUIVER_API_KEY=

# --- Capital ceiling ---
# Sizing math uses min(actual_equity, this). Excess sits as untouched cash.
# Raising this is a deliberate two-step: edit + container restart. See plan.
MANAGED_EQUITY_CEILING_USD=200

# --- Strategy switches ---
STRATEGY_MEAN_REVERSION_ENABLED=true
STRATEGY_POLITICAL_ENABLED=false

# --- Paths inside container (don't change unless you also change docker volume mounts) ---
DATA_DIR=/data
LOG_DIR=/logs
